# EverDream Environment Variables
# Copy this to .env and fill in your values

# Supabase Configuration (required for cloud sync)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Optional: Direct Anthropic API key (fallback for dream analysis)
# VITE_ANTHROPIC_API_KEY=sk-ant-xxx

# Optional: HuggingFace Inference API key (fallback for image generation)
# VITE_HF_INFERENCE_API_KEY=hf_xxx
