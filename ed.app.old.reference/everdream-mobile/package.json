{
  "name": "everdream-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "demo:web": "expo export --platform web --output-dir web-demo && node ./scripts/patch-web-demo.mjs && npx http-server web-demo -p 4173 -c-1",
    "typecheck": "tsc --noEmit",
    "doctor": "npx expo-doctor",
    "check": "npm run typecheck && npx expo-doctor"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.104.0",
    "expo": "~54.0.34",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-camera": "~17.0.10",
    "expo-file-system": "~19.0.22",
    "expo-local-authentication": "~17.0.8",
    "expo-network": "~8.0.8",
    "expo-router": "^3.5.23",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "idb-keyval": "^6.2.2",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
